[user]
    name = Valentin-Guillet
    email = guillet.valentin95240@gmail.com
[core]
    editor = vim
[color]
    diff = auto
    branch = auto
    status = auto
[color "diff"]
    oldMoved = black dim brightred
    newMoved = black dim brightgreen
[init]
    defaultBranch = main
[alias]
    br = branch
    cam = commit -am
    cm = commit -m
    l = log --oneline --graph --decorate --all --color --abbrev-commit -n 10
    ll = log --oneline --graph --decorate --all --color --abbrev-commit
    la = log --graph --all --pretty=format:'%C(auto)%h %C(bold blue)<%an> %Cgreen(%ar)%C(auto)%d %C(reset) %s' --abbrev-commit --date-order
    ls = ls-files --exclude-standard
    msg = commit --amend
    st = status -s
    sw = switch
[pull]
    rebase = true
[rebase]
    autoStash = true
[push]
    default = simple
    autoSetupRemote = true
[merge]
    tool = vimdiff
[mergetool]
    keepBackup = false
    writeToTemp = true
[diff]
    algorithm = histogram
    submodule = log
    colorMoved = default
[difftool]
    prompt = false
[difftool "vimdiff"]
    cmd = vim -f -d -c \"wincmd l\" -c 'cd \"$GIT_PREFIX\"' \"$LOCAL\" \"$REMOTE\"
[rerere]
    enabled = true

[include]
    path = delta_config

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[lfs "remote"]
    searchAll = true
